# Copy this file to .env and fill in the values before running docker-compose.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=insurance
POSTGRES_PASSWORD=change_me
POSTGRES_DB=insurance_db
DATABASE_URL=postgresql+asyncpg://insurance:change_me@postgres:5432/insurance_db

# ── Memgraph ──────────────────────────────────────────────────────────────────
MEMGRAPH_HOST=memgraph
MEMGRAPH_PORT=7687

# ── Service URLs (used by api-gateway for internal routing) ──────────────────
TENANT_SERVICE_URL=http://tenant-service:8001
RISK_ENGINE_URL=http://risk-engine:8002
DECISION_ENGINE_URL=http://decision-engine:8003

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
